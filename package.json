{
  "name": "cv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:axe": "playwright test tests/e2e/accessibility.spec.ts",
    "lhci:mobile": "lhci autorun --config=./lighthouserc.json",
    "lhci:desktop": "LHCI_COLLECT__SETTINGS__PRESET=desktop lhci autorun --config=./lighthouserc.json",
    "lhci": "npm run lhci:mobile && npm run lhci:desktop"
  },
  "dependencies": {
    "next": "16.1.6",
    "next-international": "^1.3.1",
    "framer-motion": "^10.12.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
